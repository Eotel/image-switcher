{
  "name": "image-switcher",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n express,vite -c blue,green \"node server.js\" \"vp dev\"",
    "build": "vp build",
    "preview": "NODE_ENV=production node server.js",
    "start": "node server.js",
    "check": "vp check",
    "licenses": "node scripts/generate-licenses.js",
    "licenses:check": "license-checker-rseidelsohn --production --failOn 'GPL-2.0;GPL-3.0;AGPL-3.0'"
  },
  "dependencies": {
    "express": "^4.21.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "lefthook": "^2.1.4",
    "license-checker-rseidelsohn": "^4.4.2",
    "license-report": "^6.8.2",
    "vite-plus": "^0.1.13"
  }
}
